{
  "name": "codex-designer",
  "private": true,
  "version": "0.6.1",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "pack": "npm run build && node scripts/pack.mjs",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.codex.designer",
    "productName": "Codex Designer",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "asarUnpack": [
      "**/node_modules/@openai/codex-sdk/vendor/**"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "category": "Development",
      "icon": "build/icon.png",
      "target": [
        "AppImage",
        "tar.gz"
      ]
    }
  },
  "dependencies": {
    "@openai/codex-sdk": "^0.92.0",
    "dompurify": "^3.1.7",
    "marked": "^12.0.2",
    "material-symbols": "^0.40.2",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@vitejs/plugin-vue": "^6.0.3",
    "autoprefixer": "^10.4.20",
    "electron": "^35.7.5",
    "electron-builder": "^26.4.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.2.2",
    "vite": "^6.4.1",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vue-tsc": "^2.0.26"
  }
}
